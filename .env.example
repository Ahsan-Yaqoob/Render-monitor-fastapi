RENDER_API_KEY="your_render_api_key_here"
# The id of the service you want to MONITOR (NOT this monitor's own id).
# Do not name this RENDER_SERVICE_ID — that name is reserved/auto-injected by Render.
MONITOR_SERVICE_ID="srv-xxxxxxxxxxxxxxxxxxxx"
AI_BACKEND_URL="https://your-backend.onrender.com"
EMAIL_SENDER="your_gmail@gmail.com"
EMAIL_PASSWORD="your_gmail_app_password"
EMAIL_RECEIVER="alert_recipient@example.com"
FASTAPI_PORT=8000
FASTAPI_HOST=0.0.0.0
DEBUG=False
